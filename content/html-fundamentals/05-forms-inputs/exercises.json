    {
      "title": "Create a Registration Form",
      "description": "Build a complete registration form with various input types and validation.",
      "tasks": [
        "Create form with POST method",
        "Add text inputs for name and username",
        "Add email input with validation",
        "Add password input with minlength",
        "Add date input for birthday",
        "Add number input for age",
        "Add checkbox for terms agreement",
        "Add submit button",
        "Use proper labels for all inputs"
      ],
      "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Registration Form</title>\n    <style>\n        form {\n            max-width: 400px;\n            margin: 20px auto;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 8px;\n        }\n        .form-group {\n            margin-bottom: 15px;\n        }\n        label {\n            display: block;\n            margin-bottom: 5px;\n            font-weight: bold;\n        }\n        input {\n            width: 100%;\n            padding: 8px;\n            border: 1px solid #ddd;\n            border-radius: 4px;\n            box-sizing: border-box;\n        }\n        button {\n            background: #4CAF50;\n            color: white;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n        button:hover {\n            background: #45a049;\n        }\n    </style>\n</head>\n<body>\n    <form action=\"/register\" method=\"POST\">\n        <h2>Create Account</h2>\n        \n        <div class=\"form-group\">\n            <label for=\"fullname\">Full Name:</label>\n            <input type=\"text\" id=\"fullname\" name=\"fullname\" required placeholder=\"John Doe\">\n        </div>\n        \n        <div class=\"form-group\">\n            <label for=\"username\">Username:</label>\n            <input type=\"text\" id=\"username\" name=\"username\" required minlength=\"3\" maxlength=\"20\" placeholder=\"johndoe\">\n        </div>\n        \n        <div class=\"form-group\">\n            <label for=\"email\">Email:</label>\n            <input type=\"email\" id=\"email\" name=\"email\" required placeholder=\"you@example.com\">\n        </div>\n        \n        <div class=\"form-group\">\n            <label for=\"password\">Password:</label>\n            <input type=\"password\" id=\"password\" name=\"password\" required minlength=\"8\" placeholder=\"Minimum 8 characters\">\n        </div>\n        \n        <div class=\"form-group\">\n            <label for=\"birthday\">Birthday:</label>\n            <input type=\"date\" id=\"birthday\" name=\"birthday\" required>\n        </div>\n        \n        <div class=\"form-group\">\n            <label for=\"age\">Age:</label>\n            <input type=\"number\" id=\"age\" name=\"age\" min=\"18\" max=\"120\" required>\n        </div>\n        \n        <div class=\"form-group\">\n            <label>\n                <input type=\"checkbox\" name=\"terms\" required>\n                I agree to the Terms and Conditions\n            </label>\n        </div>\n        \n        <button type=\"submit\">Create Account</button>\n    </form>\n</body>\n</html>"
    },
    {
      "title": "Build a Survey Form",
      "description": "Create a survey form with radio buttons, checkboxes, and dropdown menus.",
      "tasks": [
        "Add radio buttons for single-choice questions",
        "Add checkboxes for multiple-choice questions",
        "Add select dropdown for options",
        "Add textarea for comments",
        "Group related fields with fieldset",
        "Add proper labels and legends"
      ],
      "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Developer Survey</title>\n    <style>\n        form {\n            max-width: 600px;\n            margin: 20px auto;\n            padding: 20px;\n        }\n        fieldset {\n            margin-bottom: 20px;\n            padding: 15px;\n            border: 1px solid #ddd;\n            border-radius: 8px;\n        }\n        legend {\n            font-weight: bold;\n            padding: 0 10px;\n        }\n        .form-group {\n            margin: 10px 0;\n        }\n        label {\n            display: block;\n            margin: 5px 0;\n        }\n        textarea {\n            width: 100%;\n            padding: 8px;\n            border: 1px solid #ddd;\n            border-radius: 4px;\n            min-height: 100px;\n        }\n        button {\n            background: #2196F3;\n            color: white;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n    <form action=\"/survey\" method=\"POST\">\n        <h2>Developer Survey</h2>\n        \n        <fieldset>\n            <legend>Experience Level</legend>\n            <div class=\"form-group\">\n                <label>\n                    <input type=\"radio\" name=\"experience\" value=\"beginner\" checked> Beginner (0-2 years)\n                </label>\n                <label>\n                    <input type=\"radio\" name=\"experience\" value=\"intermediate\"> Intermediate (2-5 years)\n                </label>\n                <label>\n                    <input type=\"radio\" name=\"experience\" value=\"advanced\"> Advanced (5+ years)\n                </label>\n            </div>\n        </fieldset>\n        \n        <fieldset>\n            <legend>Technologies Used (select all that apply)</legend>\n            <div class=\"form-group\">\n                <label>\n                    <input type=\"checkbox\" name=\"tech\" value=\"html\"> HTML\n                </label>\n                <label>\n                    <input type=\"checkbox\" name=\"tech\" value=\"css\"> CSS\n                </label>\n                <label>\n                    <input type=\"checkbox\" name=\"tech\" value=\"javascript\"> JavaScript\n                </label>\n                <label>\n                    <input type=\"checkbox\" name=\"tech\" value=\"python\"> Python\n                </label>\n            </div>\n        </fieldset>\n        \n        <fieldset>\n            <legend>Additional Information</legend>\n            <div class=\"form-group\">\n                <label for=\"country\">Country:</label>\n                <select id=\"country\" name=\"country\" required>\n                    <option value=\"\" disabled selected>Select your country</option>\n                    <option value=\"us\">United States</option>\n                    <option value=\"uk\">United Kingdom</option>\n                    <option value=\"ca\">Canada</option>\n                    <option value=\"au\">Australia</option>\n                    <option value=\"other\">Other</option>\n                </select>\n            </div>\n            \n            <div class=\"form-group\">\n                <label for=\"comments\">Comments:</label>\n                <textarea id=\"comments\" name=\"comments\" placeholder=\"Share your thoughts...\" maxlength=\"500\"></textarea>\n            </div>\n        </fieldset>\n        \n        <button type=\"submit\">Submit Survey</button>\n    </form>\n</body>\n</html>"
    },
    {
      "title": "Create a Contact Form with Validation",
      "description": "Build a contact form with HTML5 validation and proper error handling.",
      "tasks": [
        "Add required fields for name and email",
        "Add pattern validation for phone number",
        "Add maxlength for message",
        "Use fieldset for organization",
        "Add proper labels",
        "Style the form with CSS"
      ],
      "solution": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Contact Form</title>\n    <style>\n        form {\n            max-width: 500px;\n            margin: 20px auto;\n            padding: 20px;\n            background: #f9f9f9;\n            border-radius: 8px;\n        }\n        fieldset {\n            border: none;\n            padding: 0;\n        }\n        legend {\n            font-size: 1.2em;\n            font-weight: bold;\n            margin-bottom: 15px;\n        }\n        .form-group {\n            margin-bottom: 15px;\n        }\n        label {\n            display: block;\n            margin-bottom: 5px;\n            font-weight: bold;\n        }\n        input, textarea, select {\n            width: 100%;\n            padding: 10px;\n            border: 1px solid #ddd;\n            border-radius: 4px;\n            box-sizing: border-box;\n        }\n        input:invalid, textarea:invalid {\n            border-color: #ff4444;\n        }\n        input:valid, textarea:valid {\n            border-color: #4CAF50;\n        }\n        button {\n            background: #4CAF50;\n            color: white;\n            padding: 12px 24px;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n            font-size: 16px;\n        }\n        button:hover {\n            background: #45a049;\n        }\n    </style>\n</head>\n<body>\n    <form action=\"/contact\" method=\"POST\">\n        <fieldset>\n            <legend>Contact Us</legend>\n            \n            <div class=\"form-group\">\n                <label for=\"name\">Name *</label>\n                <input type=\"text\" id=\"name\" name=\"name\" required minlength=\"2\" maxlength=\"50\" placeholder=\"Your name\">\n            </div>\n            \n            <div class=\"form-group\">\n                <label for=\"email\">Email *</label>\n                <input type=\"email\" id=\"email\" name=\"email\" required placeholder=\"you@example.com\">\n            </div>\n            \n            <div class=\"form-group\">\n                <label for=\"phone\">Phone (optional)</label>\n                <input type=\"tel\" id=\"phone\" name=\"phone\" pattern=\"[0-9]{3}-[0-9]{3}-[0-9]{4}\" placeholder=\"123-456-7890\">\n            </div>\n            \n            <div class=\"form-group\">\n                <label for=\"subject\">Subject *</label>\n                <select id=\"subject\" name=\"subject\" required>\n                    <option value=\"\" disabled selected>Select a subject</option>\n                    <option value=\"general\">General Inquiry</option>\n                    <option value=\"support\">Technical Support</option>\n                    <option value=\"feedback\">Feedback</option>\n                    <option value=\"other\">Other</option>\n                </select>\n            </div>\n            \n            <div class=\"form-group\">\n                <label for=\"message\">Message *</label>\n                <textarea id=\"message\" name=\"message\" required minlength=\"10\" maxlength=\"1000\" rows=\"5\" placeholder=\"How can we help you? (minimum 10 characters)\"></textarea>\n            </div>\n            \n            <button type=\"submit\">Send Message</button>\n        </fieldset>\n    </form>\n</body>\n</html>"
    }
  ]
}