{
  "topicId": "01-html-basics",
  "type": "comparison",
  "estimatedMinutes": 10,
  "comparisons": [
    {
      "title": "Proper vs Improper Document Structure",
      "before": {
        "code": "<html>\n<head>\n<title>My Page</title>\n</head>\n<body>\n<div>\n<div>\n<h1>Welcome</h1>\n<p>Content here</p>\n</div>\n</div>\n</body>\n</html>",
        "description": "Missing DOCTYPE, no semantic elements, excessive nesting, no language attribute"
      },
      "after": {
        "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>My Page</title>\n</head>\n<body>\n    <header>\n        <h1>Welcome</h1>\n    </header>\n    <main>\n        <p>Content here</p>\n    </main>\n</body>\n</html>",
        "description": "Proper DOCTYPE, language declaration, viewport meta, semantic elements"
      }
    },
    {
      "title": "Semantic vs Non-Semantic HTML",
      "before": {
        "code": "<div class=\"header\">\n    <div class=\"nav\">\n        <a href=\"/\">Home</a>\n    </div>\n</div>\n<div class=\"content\">\n    <div class=\"article\">\n        <div class=\"title\">Article Title</div>\n        <div class=\"text\">Article content...</div>\n    </div>\n</div>\n<div class=\"footer\">\n    <p>Copyright 2026</p>\n</div>",
        "description": "Using divs for everything - poor accessibility, no semantic meaning"
      },
      "after": {
        "code": "<header>\n    <nav>\n        <a href=\"/\">Home</a>\n    </nav>\n</header>\n<main>\n    <article>\n        <h1>Article Title</h1>\n        <p>Article content...</p>\n    </article>\n</main>\n<footer>\n    <p>Copyright 2026</p>\n</footer>",
        "description": "Semantic elements provide meaning, improve accessibility, better SEO"
      }
    },
    {
      "title": "Image Accessibility",
      "before": {
        "code": "<img src=\"photo.jpg\">\n<img src=\"logo.png\" alt=\"\">\n<img src=\"chart.gif\" alt=\"image of chart showing sales data for Q4 2025 with breakdown by region\">\n<img src=\"banner.jpg\" alt=\"banner background decoration image that is purely decorative and doesn't convey information\">\n<img src=\"infographic.png\" alt=\"Click here to see the full infographic about climate change statistics and projections for the next decade including temperature rise sea level changes and extreme weather events frequency\">\n<img src=\"icon.svg\" alt=\"home icon navigation button link\">\n<img src=\"photo.jpg\" alt=\"A golden retriever playing fetch in a sunny park\">\n<img src=\"team.jpg\" alt=\"Our team of 5 developers brainstorming around a whiteboard\">\n<img src=\"product.jpg\" alt=\"Wireless noise-cancelling headphones in matte black\">\n<img src=\"chart.png\" alt=\"Bar chart showing 40% increase in user engagement\">",
        "description": "Various issues: missing alt, empty alt, overly verbose alt, redundant alt text"
      },
      "after": {
        "code": "<!-- Informative image -->\n<img src=\"photo.jpg\" alt=\"A golden retriever playing fetch in a sunny park\">\n\n<!-- Decorative image (empty alt for screen readers) -->\n<img src=\"banner.jpg\" alt=\"\">\n\n<!-- Complex image with brief alt + detailed description -->\n<img src=\"chart.png\" alt=\"Bar chart showing 40% increase in user engagement\">\n\n<!-- Icon that serves a purpose -->\n<img src=\"icon.svg\" alt=\"Home\">\n\n<!-- Concise, meaningful alt text -->\n<img src=\"team.jpg\" alt=\"Team brainstorming around a whiteboard\">\n<img src=\"product.jpg\" alt=\"Wireless noise-cancelling headphones in matte black\">",
        "description": "Meaningful alt text, proper empty alt for decorative images, concise descriptions"
      }
    },
    {
      "title": "Form Element Best Practices",
      "before": {
        "code": "<form>\n    <div>Name: <input type=\"text\"></div>\n    <div>Email: <input type=\"text\"></div>\n    <div>Message: <input type=\"text\"></div>\n    <div><input type=\"submit\" value=\"Send\"></div>\n</form>",
        "description": "No labels, no input types, no validation, no accessibility"
      },
      "after": {
        "code": "<form action=\"/submit\" method=\"POST\">\n    <div>\n        <label for=\"name\">Name:</label>\n        <input type=\"text\" id=\"name\" name=\"name\" required placeholder=\"Enter your name\">\n    </div>\n    <div>\n        <label for=\"email\">Email:</label>\n        <input type=\"email\" id=\"email\" name=\"email\" required placeholder=\"you@example.com\">\n    </div>\n    <div>\n        <label for=\"message\">Message:</label>\n        <textarea id=\"message\" name=\"message\" rows=\"4\" required></textarea>\n    </div>\n    <button type=\"submit\">Send</button>\n</form>",
        "description": "Proper labels, correct input types, validation attributes, accessible markup"
      }
    }
  ],
  "insights": [
    "Always include DOCTYPE declaration for consistent rendering across browsers",
    "Use semantic HTML elements to improve accessibility and SEO",
    "Provide meaningful alt text for informative images, empty alt for decorative ones",
    "Associate labels with form inputs using the for/id pattern",
    "Include viewport meta tag for responsive design"
  ]
}