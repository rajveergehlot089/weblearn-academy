PORT=2007
NODE_ENV=development
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-secret-here
ALLOWED_ORIGINS=http://localhost:2007

# PostgreSQL (Neon recommended for production)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGDATABASE=weblearn_academy
# PGPASSWORD=your-password
# PGSSL=true  # Set to 'true' for Neon/production

# Admin setup (run once, then remove or leave blank)
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=YourSecurePassword123!

# Email (Resend — get API key at https://resend.com)
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=WebLearn Academy <onboarding@resend.dev>
# APP_URL=http://localhost:2007
